# Redis (local)
REDIS_HOST=redis
REDIS_PORT=6379

# Proxy: use either PROXY_URL or the split PROXY_* fields below.
# Supported schemes: http, https, socks4, socks5
# PROXY_PROVIDER=generic
# Supported providers:
# generic, decodo, smartproxy, brightdata, oxylabs, thordata,
# lunaproxy, netnut, soax, scrapeops, proxyempire, iproyal, webshare
#
# Examples:
# Decodo sticky ports:
# PROXY_PROVIDER=decodo
# PROXY_HOST=us.decodo.com
# PROXY_PORT=10001
#
# Thordata / LunaProxy username sessions:
# PROXY_PROVIDER=thordata
# PROXY_HOST=treyklah.na.thordata.net
# PROXY_PORT=9999
# PROXY_USERNAME=td-customer-xxxxx-country-US-sessid-old-sesstime-30
#
# Bright Data session token:
# PROXY_PROVIDER=brightdata
# PROXY_URL=http://brd-customer-zone-resi-session-old:password@brd.superproxy.io:33335
#
# Oxylabs sticky ports:
# PROXY_PROVIDER=oxylabs
# PROXY_HOST=pr.oxylabs.io
# PROXY_PORT=10001
#
# SOAX session tokens:
# PROXY_PROVIDER=soax
# PROXY_URL=http://package-12345-country-us-sessionid-old-sessionlength-600:password@proxy.soax.com:5000
#
# PROXY_URL=http://user:pass@127.0.0.1:8080
PROXY_SCHEME=http
PROXY_HOST=127.0.0.1
PROXY_PORT=8080
# PROXY_USERNAME=your-username
# PROXY_PASSWORD=your-password

# Optional browser fingerprint alignment
# BROWSER_LOCALE=en-US
# BROWSER_TIMEZONE=America/New_York
# BROWSER_ACCEPT_LANGUAGE=en-US,en;q=0.9

DEBUG_ENABLED=false
