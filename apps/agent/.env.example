# Redis (local)
REDIS_HOST=redis
REDIS_PORT=6379

PROXY=http://127.0.0.1:8080
# If your proxy uses sticky sessions, include any session pattern in username
# (e.g. `...-sessid-anything-...`, `...-session-anything-...`, `...{{SESSID}}...`).
# The worker generates a fresh session id before each browser launch and rotates on retry.
PROXY_USERNAME=changeme
PROXY_PASSWORD=changeme

DEBUG_ENABLED=false
