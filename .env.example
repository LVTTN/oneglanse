# Database connections
DATABASE_URL=postgresql://user:password@db:5432/mydb
CLICKHOUSE_URL=http://clickhouse:8123

# Container registry namespace (used by docker-compose image URLs)
GHCR_USERNAME=your-github-username
PNPM_VERSION=10.16.0
CAMOUFOX_PIP_SPEC=cloverlabs-camoufox[geoip]
CAMOUFOX_BROWSER_CHANNEL=official/prerelease

# App URLs
# Server-side (Docker internal)
APP_URL=http://web:3000
API_BASE_URL=http://web:3000
# Client-side (browser - must be external URL)
BETTER_AUTH_URL=https://app.yourdomain.com
NEXT_PUBLIC_API_URL=https://app.yourdomain.com
# Redis
REDIS_URL=redis://redis:6379
INTERNAL_CRON_SECRET=changeme

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mydb

CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=password

# Auth + API keys
BETTER_AUTH_SECRET=changeme
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme

# Redis (local)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# Agent runtime/auth
AGENT_RUNTIME_ENV=local
# Host path mounted into both containers as /storage on the VPS.
# AGENT_STORAGE_HOST_PATH=/opt/oneglanse/storage
# Optional explicit auth root. Defaults to /storage/auth on VPS and
# .oneglanse-storage/auth locally.
# AGENT_AUTH_ROOT_DIR=/storage/auth
# If you capture auth locally for a VPS, point these at the VPS auth API.
# AGENT_AUTH_UPLOAD_URL=https://your-vps-host:3333/auth/sessions
# AGENT_AUTH_UPLOAD_TOKEN=changeme
# AGENT_API_HOST=0.0.0.0
# AGENT_API_PORT=3333

AGENT_WORKER_CONCURRENCY=1
# Proxies are only used when AGENT_RUNTIME_ENV=vps.
# PROXY_HOST=127.0.0.1
# PROXY_PORT=8080
# Optional auth:
# PROXY_USERNAME=your-username
# PROXY_PASSWORD=your-password

OPENAI_API_KEY=changeme
DEBUG_ENABLED=false
